{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "organicoffer.vercel.app" }],
      "destination": "https://receitasdavovotereza.site/:path*",
      "permanent": true
    },
    { "source": "/blog", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/artigos/:slug", "destination": "/?post=:slug" },
    { "source": "/categoria/:slug", "destination": "/?category=:slug" }
  ]
}
